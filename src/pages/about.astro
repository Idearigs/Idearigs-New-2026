---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

const stats = [
  { value: '10+', label: 'Years in Business' },
  { value: '500+', label: 'Happy Clients' },
  { value: '50+', label: 'Team Members' },
  { value: '15+', label: 'Countries Served' }
];

const values = [
  {
    title: 'Innovation First',
    description: 'We constantly push boundaries and embrace new technologies to deliver cutting-edge solutions.',
    icon: 'lightbulb'
  },
  {
    title: 'Client Success',
    description: 'Your success is our success. We measure our performance by the results we deliver for you.',
    icon: 'trophy'
  },
  {
    title: 'Transparency',
    description: 'Open communication and honest relationships are the foundation of everything we do.',
    icon: 'eye'
  },
  {
    title: 'Excellence',
    description: 'We hold ourselves to the highest standards in every project, no matter the size.',
    icon: 'star'
  }
];

const team = [
  {
    name: 'Alex Thompson',
    role: 'CEO & Founder',
    initials: 'AT',
    bio: '15+ years in technology leadership'
  },
  {
    name: 'Sarah Chen',
    role: 'CTO',
    initials: 'SC',
    bio: 'Former Google engineer'
  },
  {
    name: 'Michael Rodriguez',
    role: 'Head of Design',
    initials: 'MR',
    bio: 'Award-winning UX designer'
  },
  {
    name: 'Emily Watson',
    role: 'VP of Marketing',
    initials: 'EW',
    bio: 'Digital marketing expert'
  }
];

const timeline = [
  { year: '2014', title: 'Founded', description: 'Started with a vision to transform business technology' },
  { year: '2016', title: 'First 100 Clients', description: 'Reached our first major milestone' },
  { year: '2018', title: 'Global Expansion', description: 'Opened offices in 5 new countries' },
  { year: '2020', title: 'Enterprise Solutions', description: 'Launched enterprise-grade software division' },
  { year: '2022', title: 'Industry Recognition', description: 'Named Top Tech Company by TechReview' },
  { year: '2024', title: '500+ Clients', description: 'Celebrating our growing community of clients' }
];
---

<BaseLayout
  title="About Us"
  description="Learn about Idearigs - our mission, values, team, and the journey that made us a leading technology solutions provider."
>
  <!-- Hero Section -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-24 bg-gradient-subtle">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center animate-on-scroll">
        <span class="badge-accent mb-6">About Idearigs</span>
        <h1 class="mb-6">
          Transforming businesses through
          <span class="text-accent">technology</span>
        </h1>
        <p class="text-lg text-primary/70 mb-8 max-w-2xl mx-auto">
          We're a team of passionate technologists, designers, and strategists dedicated to helping businesses thrive in the digital age.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-primary">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {stats.map((stat, index) => (
          <div class={`animate-on-scroll animation-delay-${(index + 1) * 100}`}>
            <p class="text-4xl md:text-5xl font-bold text-white mb-2">{stat.value}</p>
            <p class="text-white/60">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span class="badge-accent mb-4">Our Mission</span>
          <h2 class="mb-6">
            Empowering businesses to
            <span class="text-accent">reach their potential</span>
          </h2>
          <p class="text-lg text-primary/70 mb-6">
            We believe that every business deserves access to world-class technology solutions. Our mission is to bridge the gap between innovation and implementation, making powerful tools accessible to businesses of all sizes.
          </p>
          <p class="text-lg text-primary/70">
            From startups to enterprises, we partner with our clients to understand their unique challenges and deliver solutions that drive real, measurable results.
          </p>
        </div>

        <!-- Values grid -->
        <div class="grid sm:grid-cols-2 gap-6">
          {values.map((value, index) => (
            <div class={`bg-background rounded-xl p-6 animate-on-scroll animation-delay-${(index + 1) * 100}`}>
              <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center mb-4">
                {value.icon === 'lightbulb' && (
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                )}
                {value.icon === 'trophy' && (
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                  </svg>
                )}
                {value.icon === 'eye' && (
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                )}
                {value.icon === 'star' && (
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  </svg>
                )}
              </div>
              <h3 class="font-semibold text-primary mb-2">{value.title}</h3>
              <p class="text-sm text-primary/70">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="section-padding bg-background">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <span class="badge-accent mb-4">Our Team</span>
        <h2 class="mb-6">
          Meet the people behind
          <span class="text-accent">Idearigs</span>
        </h2>
        <p class="text-lg text-primary/70">
          A diverse team of experts united by a shared passion for technology and innovation.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
        {team.map((member, index) => (
          <div class={`text-center animate-on-scroll animation-delay-${(index + 1) * 100}`}>
            <div class="w-24 h-24 bg-gradient-to-br from-primary to-accent rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-white">{member.initials}</span>
            </div>
            <h3 class="font-semibold text-primary">{member.name}</h3>
            <p class="text-accent text-sm mb-2">{member.role}</p>
            <p class="text-sm text-primary/60">{member.bio}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <p class="text-primary/70 mb-4">Want to join our team?</p>
        <Button href="/careers" variant="secondary">
          View Open Positions
        </Button>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <span class="badge-accent mb-4">Our Journey</span>
        <h2 class="mb-6">
          A decade of
          <span class="text-accent">growth & innovation</span>
        </h2>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-accent/20 -translate-x-1/2"></div>

          {timeline.map((item, index) => (
            <div class={`relative flex items-center gap-8 mb-12 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} animate-on-scroll animation-delay-${(index + 1) * 100}`}>
              <div class={`flex-1 ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'} pl-12 md:pl-0`}>
                <div class="bg-background rounded-xl p-6">
                  <span class="text-accent font-bold">{item.year}</span>
                  <h3 class="text-xl font-semibold text-primary mt-1">{item.title}</h3>
                  <p class="text-primary/70 mt-2">{item.description}</p>
                </div>
              </div>

              <!-- Circle marker -->
              <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-accent rounded-full -translate-x-1/2 ring-4 ring-white"></div>

              <div class="hidden md:block flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>
