---
import BaseLayout from '../layouts/BaseLayout.astro';

const plan = Astro.url.searchParams.get('plan') ?? 'standard';

const plans: Record<string, {
  name: string;
  subtitle: string;
  price: string;
  color: string;
  bg: string;
  border: string;
  steps: string[];
  eta: string;
}> = {
  standard: {
    name: 'Standard',
    subtitle: 'Managed Support',
    price: '£110/mo',
    color: '#6366f1',
    bg: '#eef2ff',
    border: '#c7d2fe',
    eta: 'within 1 business day',
    steps: [
      'Payment confirmed — your subscription is now active.',
      'An Idearigs engineer will contact you within 1 business day to gather your server credentials.',
      'We will set up SSH key authentication and begin onboarding your servers.',
      'Your 24/7 monitoring dashboard and daily backups will be live within 24 hours of onboarding.',
      'You will receive your first automated maintenance report within 30 days.',
    ],
  },
  professional: {
    name: 'Professional',
    subtitle: 'Performance',
    price: '£220/mo',
    color: '#046645',
    bg: '#f0fdf4',
    border: '#bbf7d0',
    eta: 'within 1 business day',
    steps: [
      'Payment confirmed — your subscription is now active.',
      'An Idearigs engineer will contact you within 1 business day to gather your server credentials.',
      'We will configure advanced WAF, malware scanning, and 1-min interval monitoring.',
      'Hourly database backups and performance baselines will be established within 24 hours of onboarding.',
      'You will receive your first automated maintenance report within 30 days.',
    ],
  },
  enterprise: {
    name: 'Enterprise',
    subtitle: 'Enterprise Infrastructure Tier',
    price: '£385/mo',
    color: '#8b5cf6',
    bg: '#f5f3ff',
    border: '#ddd6fe',
    eta: 'within a few hours',
    steps: [
      'Payment confirmed — your Enterprise Infrastructure Tier subscription is now active.',
      'A senior Idearigs engineer will contact you within a few hours to begin priority onboarding.',
      'We will deploy your Standardized High-Availability Configuration and connect real-time telemetry.',
      'Multi-region monitoring, IDS, load balancing, and your 4-hour Priority SLA go live within 24 hours.',
      'Your first Weekly Automated Security Audit Report will be delivered within 7 days.',
    ],
  },
};

const p = plans[plan] ?? plans['standard'];
---

<BaseLayout
  title="Thank You — Your Subscription is Active"
  description="Thank you for subscribing to Idearigs managed server services. We are starting the process now."
>
  <section class="min-h-screen bg-[#FCFBFA] flex flex-col items-center justify-center pt-32 pb-20 px-4">

    <!-- Animated checkmark ring -->
    <div class="relative mb-8">
      <div class="w-24 h-24 rounded-full flex items-center justify-center" style={`background:${p.bg};border:2px solid ${p.border};`}>
        <svg class="w-11 h-11" style={`color:${p.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <!-- pulse ring -->
      <div class="absolute inset-0 rounded-full animate-ping opacity-20" style={`background:${p.color};animation-duration:2s;`}></div>
    </div>

    <!-- Heading -->
    <div class="text-center max-w-xl mb-10">
      <p class="text-xs font-bold uppercase tracking-widest mb-2" style={`color:${p.color};`}>
        {p.name} Plan — {p.price}
      </p>
      <h1 class="text-3xl sm:text-4xl font-black text-gray-900 mb-3">
        We're starting the process now.
      </h1>
      <p class="text-gray-500 text-base leading-relaxed">
        Your subscription is confirmed and our team is already on it.
        Expect to hear from us <strong class="text-gray-700">{p.eta}</strong>.
      </p>
    </div>

    <!-- Steps card -->
    <div class="w-full max-w-lg bg-white rounded-2xl border shadow-sm overflow-hidden" style={`border-color:${p.border};box-shadow:0 8px 32px ${p.color}10;`}>
      <!-- Card header -->
      <div class="px-6 py-4 border-b flex items-center gap-3" style={`background:${p.bg};border-color:${p.border};`}>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background:${p.color};`}>
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="font-bold text-gray-900 text-sm">What happens next</p>
      </div>

      <!-- Step list -->
      <ul class="divide-y divide-gray-50">
        {p.steps.map((step, i) => (
          <li class="flex items-start gap-4 px-6 py-4">
            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-xs font-black text-white" style={`background:${i === 0 ? p.color : '#d1d5db'};`}>
              {i + 1}
            </div>
            <p class={`text-sm leading-relaxed ${i === 0 ? 'text-gray-900 font-semibold' : 'text-gray-500'}`}>{step}</p>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact note -->
    <p class="mt-8 text-sm text-gray-400 text-center max-w-sm">
      Questions? Email us at{' '}
      <a href="mailto:hello@idearigs.com" class="font-semibold hover:underline" style={`color:${p.color};`}>hello@idearigs.com</a>{' '}
      — we reply fast.
    </p>

    <!-- Back link -->
    <a href="/" class="mt-6 inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to homepage
    </a>

  </section>
</BaseLayout>
