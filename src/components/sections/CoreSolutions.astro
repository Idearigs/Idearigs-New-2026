---
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

const solutions = [
  {
    title: 'POS Systems',
    description: 'Complete point of sale solutions for retail, restaurants, and hospitality. Streamline transactions and manage inventory with ease.',
    icon: 'pos',
    variant: 'pastel-green' as const,
    href: '/pos-systems',
    features: ['Inventory Management', 'Multi-location Support', 'Real-time Analytics']
  },
  {
    title: 'Web Development',
    description: 'Modern, responsive websites and web applications built with cutting-edge technologies. From landing pages to complex platforms.',
    icon: 'web',
    variant: 'pastel-blue' as const,
    href: '/web-development',
    features: ['Custom Development', 'E-commerce Solutions', 'Progressive Web Apps']
  },
  {
    title: 'Digital Marketing',
    description: 'Data-driven marketing strategies that deliver results. SEO, social media, PPC, and content marketing to grow your brand.',
    icon: 'marketing',
    variant: 'pastel-purple' as const,
    href: '/digital-marketing',
    features: ['SEO Optimization', 'Social Media Marketing', 'Performance Analytics']
  }
];
---

<section id="solutions" class="section-padding bg-white">
  <div class="container-custom">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <span class="badge-accent mb-4">Our Solutions</span>
      <h2 class="mb-6">
        Everything you need to
        <span class="text-accent">grow your business</span>
      </h2>
      <p class="text-lg text-primary/70">
        Comprehensive technology solutions designed to streamline operations, enhance customer experiences, and drive sustainable growth.
      </p>
    </div>

    <!-- Solutions grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {solutions.map((solution, index) => (
        <Card variant={solution.variant} padding="lg" class={`animate-on-scroll animation-delay-${(index + 1) * 100}`}>
          <!-- Icon -->
          <div class="w-14 h-14 bg-white rounded-xl shadow-soft flex items-center justify-center mb-6">
            {solution.icon === 'pos' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            )}
            {solution.icon === 'web' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            )}
            {solution.icon === 'marketing' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />
              </svg>
            )}
          </div>

          <!-- Content -->
          <h3 class="text-xl font-semibold text-primary mb-3">{solution.title}</h3>
          <p class="text-primary/70 mb-6">{solution.description}</p>

          <!-- Features -->
          <ul class="space-y-2 mb-6">
            {solution.features.map((feature) => (
              <li class="flex items-center gap-2 text-sm text-primary/70">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <!-- Link -->
          <a href={solution.href} class="inline-flex items-center gap-2 text-accent font-medium hover:gap-3 transition-all duration-200">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </Card>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12 animate-on-scroll">
      <Button href="#contact" variant="primary">
        Discuss Your Project
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>
  </div>
</section>
