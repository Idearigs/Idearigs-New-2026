---
const services = [
  {
    title: 'Web Development',
    desc: 'From brochure sites to full e-commerce platforms — we design and build fast, modern websites that convert visitors into customers.',
    tag: 'Design & Build',
    tagColor: '#6366f1',
    tagBg: '#eef2ff',
    border: '#c7d2fe',
    icon: 'web',
    bullets: ['Custom UI/UX design', 'SEO-optimised & fast', 'CMS & e-commerce ready'],
    href: '/web-development',
  },
  {
    title: 'Business Process Automation',
    desc: 'Eliminate manual, repetitive tasks with smart automation — from invoicing and stock management to customer follow-ups and reporting.',
    tag: 'Efficiency & Growth',
    tagColor: '#10b981',
    tagBg: '#f0fdf4',
    border: '#bbf7d0',
    icon: 'bpa',
    bullets: ['Workflow automation', 'System integrations & APIs', 'Custom internal tooling'],
    href: '/contact',
  },
  {
    title: 'POS & Retail Systems',
    desc: 'TrueDesk — our all-in-one retail platform covering point of sale, repairs, HR, payroll, inventory and analytics under one login.',
    tag: 'All-in-One Platform',
    tagColor: '#f97316',
    tagBg: '#fff7ed',
    border: '#fed7aa',
    icon: 'pos',
    bullets: ['Sales & payments', 'Repair job tracking', 'HR, payroll & rota'],
    href: '/pos-systems',
  },
  {
    title: 'Digital Marketing',
    desc: 'Data-driven campaigns that grow your brand — Google Ads, social media, email marketing, and SEO tailored to your industry.',
    tag: 'Reach & Revenue',
    tagColor: '#8b5cf6',
    tagBg: '#f5f3ff',
    border: '#ddd6fe',
    icon: 'marketing',
    bullets: ['Google & social ads', 'SEO & content strategy', 'Email & CRM campaigns'],
    href: '/digital-marketing',
  },
  {
    title: 'IT Infrastructure & Cloud',
    desc: 'Reliable, secure infrastructure management — server hosting, cloud migrations, backups, monitoring, and ongoing managed support.',
    tag: 'Infrastructure',
    tagColor: '#0ea5e9',
    tagBg: '#f0f9ff',
    border: '#bae6fd',
    icon: 'cloud',
    bullets: ['Managed server hosting', 'Cloud setup & migration', '24/7 monitoring & support'],
    href: '/server-management',
  },
  {
    title: 'Cybersecurity & Compliance',
    desc: 'Protect your business with enterprise-grade security audits, vulnerability assessments, staff training, and GDPR compliance guidance.',
    tag: 'Security & Trust',
    tagColor: '#ec4899',
    tagBg: '#fdf2f8',
    border: '#fbcfe8',
    icon: 'security',
    bullets: ['Security audits & pen testing', 'GDPR & data compliance', 'Staff security training'],
    href: '/contact',
  },
];
---

<section class="section-padding bg-[#FCFBFA]">
  <div class="container-custom">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <span class="badge-accent mb-4">What We Do</span>
      <h2 class="mb-5 text-gray-900">
        Everything your business<br/>
        <span class="text-accent">needs to thrive.</span>
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed">
        From your website to your back-office systems — Idearigs delivers end-to-end technology solutions that help businesses operate smarter and grow faster.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((svc, i) => (
        <a
          href={svc.href}
          class="group relative flex flex-col bg-white rounded-2xl p-6 border hover:-translate-y-1 hover:shadow-xl transition-all duration-300 overflow-hidden"
          style={`border-color:${svc.border};`}
        >
          <!-- Top gradient wash -->
          <div class="absolute top-0 left-0 right-0 h-24 rounded-t-2xl pointer-events-none" style={`background:linear-gradient(to bottom,${svc.tagBg},transparent);`}></div>

          <!-- Hover glow -->
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`box-shadow:0 0 36px 0 ${svc.tagColor}18;`}></div>

          <div class="relative flex flex-col h-full">
            <!-- Icon + tag row -->
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center border" style={`background:${svc.tagBg};border-color:${svc.border};`}>
                {svc.icon === 'web' && <svg class="w-6 h-6" style={`color:${svc.tagColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>}
                {svc.icon === 'bpa' && <svg class="w-6 h-6" style={`color:${svc.tagColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>}
                {svc.icon === 'pos' && <svg class="w-6 h-6" style={`color:${svc.tagColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>}
                {svc.icon === 'marketing' && <svg class="w-6 h-6" style={`color:${svc.tagColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>}
                {svc.icon === 'cloud' && <svg class="w-6 h-6" style={`color:${svc.tagColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>}
                {svc.icon === 'security' && <svg class="w-6 h-6" style={`color:${svc.tagColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
              </div>
              <span class="text-xs font-bold px-2.5 py-1 rounded-full" style={`color:${svc.tagColor};background:${svc.tagBg};border:1px solid ${svc.border};`}>{svc.tag}</span>
            </div>

            <!-- Title & desc -->
            <h3 class="text-gray-900 font-bold text-lg mb-2 group-hover:text-gray-950 transition-colors">{svc.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">{svc.desc}</p>

            <!-- Bullets -->
            <ul class="space-y-1.5 mb-6 flex-1">
              {svc.bullets.map(b => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${svc.tagColor};`}></div>
                  {b}
                </li>
              ))}
            </ul>

            <!-- Link -->
            <div class="flex items-center gap-1.5 text-sm font-semibold transition-all duration-200 mt-auto" style={`color:${svc.tagColor};`}>
              Learn more
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA strip -->
    <div class="mt-14 rounded-2xl p-8 flex flex-col sm:flex-row items-center justify-between gap-6 border border-gray-100 bg-white" style="box-shadow:0 4px 24px rgba(0,0,0,0.05);">
      <div>
        <p class="text-gray-900 font-bold text-lg mb-1">Not sure which service you need?</p>
        <p class="text-gray-500 text-sm">Book a free 30-minute consultation and we'll map the right solution to your business.</p>
      </div>
      <a href="/contact" class="flex-shrink-0 inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-bold text-white text-sm transition-all hover:scale-105 hover:shadow-lg" style="background:linear-gradient(135deg,#046645,#059669);box-shadow:0 4px 16px rgba(4,102,69,0.25);">
        Book a Free Consultation
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

  </div>
</section>
