---
const reasons = [
  {
    title: 'Expert Team',
    description: 'Our team of seasoned professionals brings decades of combined experience in technology and business solutions.',
    icon: 'team',
    color: 'pastel-blue'
  },
  {
    title: 'Proven Results',
    description: 'We have a track record of delivering measurable outcomes that drive real business growth for our clients.',
    icon: 'results',
    color: 'pastel-green'
  },
  {
    title: '24/7 Support',
    description: 'Round-the-clock technical support ensures your business operations never skip a beat.',
    icon: 'support',
    color: 'pastel-purple'
  },
  {
    title: 'Custom Solutions',
    description: 'Every solution is tailored to your specific needs, ensuring perfect alignment with your business goals.',
    icon: 'custom',
    color: 'pastel-yellow'
  },
  {
    title: 'Scalable Systems',
    description: 'Our solutions grow with your business, from startup to enterprise, without missing a step.',
    icon: 'scale',
    color: 'pastel-pink'
  },
  {
    title: 'Data Security',
    description: 'Enterprise-grade security measures protect your business data and customer information.',
    icon: 'security',
    color: 'pastel-orange'
  }
];
---

<section class="section-padding bg-white">
  <div class="container-custom">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <span class="badge-accent mb-4">Why Choose Us</span>
      <h2 class="mb-6">
        The Idearigs
        <span class="text-accent">advantage</span>
      </h2>
      <p class="text-lg text-primary/70">
        We combine technical excellence with a deep understanding of business needs to deliver solutions that truly make a difference.
      </p>
    </div>

    <!-- Reasons grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {reasons.map((reason, index) => (
        <div class={`group p-6 rounded-xl bg-${reason.color} hover:shadow-soft transition-all duration-300 animate-on-scroll animation-delay-${(index + 1) * 100}`}>
          <!-- Icon -->
          <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            {reason.icon === 'team' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            )}
            {reason.icon === 'results' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {reason.icon === 'support' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            )}
            {reason.icon === 'custom' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
              </svg>
            )}
            {reason.icon === 'scale' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            )}
            {reason.icon === 'security' && (
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
          </div>

          <!-- Content -->
          <h3 class="text-xl font-semibold text-primary mb-3">{reason.title}</h3>
          <p class="text-primary/70">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
