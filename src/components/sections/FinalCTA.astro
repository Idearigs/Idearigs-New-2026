---
---

<section id="contact" class="section-padding bg-white relative overflow-hidden">

  <!-- Subtle bg blobs -->
  <div class="absolute top-0 left-0 w-[500px] h-[500px] rounded-full blur-[120px] pointer-events-none opacity-40" style="background:radial-gradient(circle,rgba(99,102,241,0.07) 0%,transparent 70%);transform:translate(-40%,-40%)"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full blur-[100px] pointer-events-none opacity-40" style="background:radial-gradient(circle,rgba(4,102,69,0.07) 0%,transparent 70%);transform:translate(40%,40%)"></div>

  <div class="container-custom relative">
    <div class="max-w-5xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-14 animate-on-scroll">
        <span class="badge-accent mb-5">Get in Touch</span>
        <h2 class="text-gray-900 mb-5">
          Let's build something<br/>
          <span class="text-gray-900">great together.</span>
        </h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">
          Tell us about your business and we'll map the right technology solution to your goals. No obligation — just an honest conversation.
        </p>
      </div>

      <div class="grid lg:grid-cols-5 gap-8 items-start">

        <!-- Contact info sidebar -->
        <div class="lg:col-span-2 space-y-5">

          <!-- Why contact card -->
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="text-gray-900 font-bold text-base mb-4">What to expect</h3>
            <div class="space-y-3">
              {[
                { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Response within 24 hours' },
                { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', text: 'Free 30-min consultation' },
                { icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', text: 'Tailored proposal at no cost' },
                { icon: 'M13 10V3L4 14h7v7l9-11h-7z', text: 'Fast, clear, no-jargon advice' },
              ].map(item => (
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 shadow-sm">
                    <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
                    </svg>
                  </div>
                  <p class="text-sm text-gray-600 font-medium">{item.text}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Direct contact -->
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="text-gray-900 font-bold text-base mb-4">Prefer to talk directly?</h3>
            <div class="space-y-3">
              <a href="tel:+441234567890" class="flex items-center gap-3 group">
                <div class="w-8 h-8 rounded-lg bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:border-accent/30 transition-colors">
                  <svg class="w-4 h-4 text-gray-500 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400">Phone</p>
                  <p class="text-sm font-semibold text-gray-800 group-hover:text-accent transition-colors">+44 (0) 123 456 7890</p>
                </div>
              </a>
              <a href="mailto:hello@idearigs.com" class="flex items-center gap-3 group">
                <div class="w-8 h-8 rounded-lg bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:border-accent/30 transition-colors">
                  <svg class="w-4 h-4 text-gray-500 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400">Email</p>
                  <p class="text-sm font-semibold text-gray-800 group-hover:text-accent transition-colors">hello@idearigs.com</p>
                </div>
              </a>
            </div>
          </div>

        </div>

        <!-- Form -->
        <div class="lg:col-span-3 bg-white rounded-2xl border border-gray-100 p-8 animate-on-scroll animation-delay-200" style="box-shadow:0 4px 32px rgba(0,0,0,0.06);">

          <form class="space-y-5" id="contact-form">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">Full Name</label>
                <input type="text" id="name" name="name" required class="input" placeholder="James Whitmore" />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">Email Address</label>
                <input type="email" id="email" name="email" required class="input" placeholder="james@company.com" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="phone" class="block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="input" placeholder="+44 (0) 000 000 0000" />
              </div>
              <div>
                <label for="service" class="block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">Service Interested In</label>
                <select id="service" name="service" class="input">
                  <option value="">Select a service...</option>
                  <option value="pos">POS & TrueDesk</option>
                  <option value="web">Web Development</option>
                  <option value="marketing">Digital Marketing</option>
                  <option value="bpa">Business Process Automation</option>
                  <option value="server">IT Infrastructure & Cloud</option>
                  <option value="security">Cybersecurity & Compliance</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">Tell us about your project</label>
              <textarea id="message" name="message" rows="4" class="input resize-none" placeholder="Describe your business and what you're looking to achieve..."></textarea>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-1">
              <p class="text-xs text-gray-400">We'll get back to you within 24 hours.</p>
              <button type="submit" class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-xl font-bold text-white text-sm transition-all hover:scale-105 hover:shadow-lg flex-shrink-0" style="background:linear-gradient(135deg,#046645,#059669);box-shadow:0 4px 16px rgba(4,102,69,0.25);">
                Send Message
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </button>
            </div>
          </form>

          <!-- Success state -->
          <div id="form-success" class="hidden text-center py-10">
            <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background:#f0fdf4;">
              <svg class="w-8 h-8" style="color:#046645;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Message received!</h3>
            <p class="text-gray-500 text-sm">Thank you for reaching out. A member of our team will be in touch within 24 hours.</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    successMessage?.classList.remove('hidden');
    form.reset();
  });
</script>
