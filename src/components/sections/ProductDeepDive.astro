                    <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${emp.status === 'Active' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700'}`}>{emp.status}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Animated cursor -->
            <div id="hr-cursor" class="absolute pointer-events-none z-20 transition-all duration-700 ease-in-out" style="left:200px;top:80px;">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 2L16 10L10 11L8 17L4 2Z" fill="white" stroke="#333" stroke-width="1.5"/>
              </svg>
              <div id="hr-tooltip" class="absolute left-5 top-0 bg-gray-900 text-white text-xs px-2 py-1 rounded-lg whitespace-nowrap opacity-0 transition-opacity duration-300">£38,400 payroll</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
// ── Tab switching ──────────────────────────────────────────────
const tabBtns = document.querySelectorAll<HTMLButtonElement>('.pd-tab-btn');
const urlText = document.getElementById('pd-url-text')!;
const urlMap: Record<string, string> = {
  pos:     'app.truedesk.co.uk/pos/dashboard',
  website: 'app.truedesk.co.uk/analytics',
  hr:      'app.truedesk.co.uk/hr/dashboard',
};

function switchTab(id: string) {
  // tabs
  tabBtns.forEach(b => {
    const active = b.dataset.tab === id;
    b.classList.toggle('bg-gray-900', active);
    b.classList.toggle('text-white', active);
    b.classList.toggle('shadow', active);
    b.classList.toggle('text-gray-500', !active);
  });
  // screens
  document.querySelectorAll('.pd-screen').forEach(s => s.classList.add('hidden'));
  document.getElementById(`pd-screen-${id}`)?.classList.remove('hidden');
  // headings
  document.querySelectorAll('.pd-heading').forEach(h => h.classList.add('hidden'));
  document.getElementById(`pd-heading-${id}`)?.classList.remove('hidden');
  // features
  document.querySelectorAll('.pd-features').forEach(f => f.classList.add('hidden'));
  document.getElementById(`pd-features-${id}`)?.classList.remove('hidden');
  // cta
  document.querySelectorAll('.pd-cta').forEach(c => c.classList.add('hidden'));
  document.getElementById(`pd-cta-${id}`)?.classList.remove('hidden');
  // url
  urlText.textContent = urlMap[id];
}

tabBtns.forEach(btn => btn.addEventListener('click', () => switchTab(btn.dataset.tab!)));

// ── Shared cursor engine (smooth lerp + click pulse) ──────────
function makeCursor(cursorEl: HTMLElement, tooltipEl: HTMLElement) {
  let curX = 200, curY = 80;   // current rendered position
  let tgtX = 200, tgtY = 80;   // target position
  let clicking = false;

  // Click ripple element
  const ripple = document.createElement('div');
  ripple.style.cssText = `
    position:absolute; width:18px; height:18px;
    border-radius:50%; background:rgba(99,102,241,0.35);
    transform:scale(0); pointer-events:none; z-index:19;
    transition: transform 0.25s ease-out, opacity 0.25s ease-out;
    margin-left:-4px; margin-top:-4px;
  `;
  cursorEl.appendChild(ripple);

  // RAF loop — lerps toward target
  function tick() {
    const ease = 0.10;
    curX += (tgtX - curX) * ease;
    curY += (tgtY - curY) * ease;
    cursorEl.style.left = curX + 'px';
    cursorEl.style.top  = curY + 'px';
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);

  function moveTo(x: number, y: number) { tgtX = x; tgtY = y; }

  function click() {
    clicking = true;
    // Scale cursor down slightly
    const svg = cursorEl.querySelector('svg') as SVGElement;
    if (svg) { svg.style.transform = 'scale(0.82)'; svg.style.transition = 'transform 0.1s'; }
    // Ripple out
    ripple.style.transform = 'scale(1.6)';
    ripple.style.opacity = '1';
    setTimeout(() => {
      if (svg) svg.style.transform = 'scale(1)';
      ripple.style.transform = 'scale(0)';
      ripple.style.opacity = '0';
      clicking = false;
    }, 220);
  }

  function showTooltip(text: string) { tooltipEl.textContent = text; tooltipEl.style.opacity = '1'; }
  function hideTooltip()              { tooltipEl.style.opacity = '0'; }

  return { moveTo, click, showTooltip, hideTooltip };
}

// ── POS cursor ────────────────────────────────────────────────
const posCursor  = document.getElementById('pos-cursor')!;
const posTooltip = document.getElementById('pos-tooltip')!;
const posToast   = document.getElementById('pos-toast')!;
const pos = makeCursor(posCursor, posTooltip);

// waypoints: {x, y, pause(ms), tooltip?, click?, toast?}
const posWaypoints = [
  { x:220, y:55,  pause:600  },                                    // move to sales card
  { x:220, y:55,  pause:500,  tooltip:'£1,284 today' },
  { x:220, y:55,  pause:300,  click:true },
  { x:220, y:55,  pause:800  },
  { x:340, y:55,  pause:500  },                                     // move to transactions
  { x:340, y:55,  pause:500,  tooltip:'47 transactions' },
  { x:340, y:55,  pause:300,  click:true },
  { x:340, y:55,  pause:700  },
  { x:240, y:185, pause:700  },                                     // move to first sale row
  { x:240, y:185, pause:500,  tooltip:'Hasitha De Silva', row:0 },
  { x:240, y:185, pause:300,  click:true, toast:true },
  { x:240, y:185, pause:900  },
  { x:240, y:215, pause:600  },                                     // second row
  { x:240, y:215, pause:500,  tooltip:'Walk-in Customer', row:1 },
  { x:240, y:215, pause:400  },
  { x:220, y:55,  pause:400  },                                     // back to top
];

let posWpIdx = 0;
let posToastTimer: ReturnType<typeof setTimeout>;

function runPosStep() {
  const wp = posWaypoints[posWpIdx % posWaypoints.length];
  pos.moveTo(wp.x, wp.y);

  if (wp.tooltip) pos.showTooltip(wp.tooltip); else pos.hideTooltip();
  if (wp.click)   setTimeout(() => pos.click(), 200);

  // highlight row
  document.querySelectorAll<HTMLElement>('.pos-sale-row').forEach(r => r.style.background = '');
  if (wp.row !== undefined) {
    const row = document.querySelectorAll<HTMLElement>('.pos-sale-row')[wp.row];
    if (row) row.style.background = '#f0f9ff';
  }

  // toast
  if (wp.toast) {
    clearTimeout(posToastTimer);
    posToast.style.opacity = '1';
    posToast.style.transform = 'translateY(0)';
    posToastTimer = setTimeout(() => {
      posToast.style.opacity = '0';
      posToast.style.transform = 'translateY(-6px)';
    }, 1800);
  }

  posWpIdx++;
  setTimeout(runPosStep, wp.pause);
}
setTimeout(runPosStep, 800);

// ── Website view switching (front → admin → front …) ──────────
const webViewFront = document.getElementById('web-view-front')!;
const webViewAdmin = document.getElementById('web-view-admin')!;
const webDots      = document.querySelectorAll<HTMLElement>('.web-dot');

let webShowingAdmin = false;

function switchWebView() {
  webShowingAdmin = !webShowingAdmin;
  if (webShowingAdmin) {
    webViewFront.style.opacity = '0';
    webViewFront.style.pointerEvents = 'none';
    webViewAdmin.style.opacity = '1';
    webViewAdmin.style.pointerEvents = 'auto';
    webDots[0]?.style && (webDots[0].style.background = '#e5e7eb');
    webDots[1]?.style && (webDots[1].style.background = '#3b82f6');
  } else {
    webViewFront.style.opacity = '1';
    webViewFront.style.pointerEvents = 'auto';
    webViewAdmin.style.opacity = '0';
    webViewAdmin.style.pointerEvents = 'none';
    webDots[0]?.style && (webDots[0].style.background = '#3b82f6');
    webDots[1]?.style && (webDots[1].style.background = '#e5e7eb');
  }
}

setInterval(switchWebView, 3500);

// ── Website cursor ────────────────────────────────────────────
const webCursor  = document.getElementById('web-cursor')!;
const webTooltip = document.getElementById('web-tooltip')!;
const webBars    = document.querySelectorAll<HTMLElement>('.web-bar');
const web = makeCursor(webCursor, webTooltip);

const webWaypoints = [
  { x:185, y:65,  pause:600 },
  { x:185, y:65,  pause:500, tooltip:'8,421 visitors' },
  { x:185, y:65,  pause:300, click:true },
  { x:185, y:65,  pause:700 },
  { x:270, y:65,  pause:500 },
  { x:270, y:65,  pause:500, tooltip:'£12,840 revenue' },
  { x:270, y:65,  pause:300, click:true },
  { x:270, y:65,  pause:700 },
  { x:330, y:310, pause:700, bar:6 },
  { x:330, y:310, pause:500, tooltip:'Sunday — peak day', bar:6 },
  { x:330, y:310, pause:300, click:true },
  { x:330, y:310, pause:600 },
  { x:290, y:310, pause:500, bar:4 },
  { x:290, y:310, pause:500, tooltip:'Friday traffic', bar:4 },
  { x:290, y:310, pause:400 },
  { x:185, y:65,  pause:400 },
];

let webWpIdx = 0;
function runWebStep() {
  if (!webShowingAdmin) { webWpIdx++; setTimeout(runWebStep, 600); return; }
  const wp = webWaypoints[webWpIdx % webWaypoints.length];
  web.moveTo(wp.x, wp.y);
  if (wp.tooltip) web.showTooltip(wp.tooltip); else web.hideTooltip();
  if (wp.click)   setTimeout(() => web.click(), 200);
  webBars.forEach((b, i) => {
    b.style.background = i === (wp.bar ?? -1)
      ? 'linear-gradient(to top,#1d4ed8,#93c5fd)'
      : 'linear-gradient(to top,#2563eb,#60a5fa)';
  });
  webWpIdx++;
  setTimeout(runWebStep, wp.pause);
}
setTimeout(runWebStep, 1200);

// ── HR cursor ─────────────────────────────────────────────────
const hrCursor  = document.getElementById('hr-cursor')!;
const hrTooltip = document.getElementById('hr-tooltip')!;
const hr = makeCursor(hrCursor, hrTooltip);

const hrWaypoints = [
  { x:185, y:60,  pause:600 },
  { x:185, y:60,  pause:500, tooltip:'24 employees' },
  { x:185, y:60,  pause:300, click:true },
  { x:185, y:60,  pause:700 },
  { x:295, y:60,  pause:500 },
  { x:295, y:60,  pause:500, tooltip:'£38,400 payroll due' },
  { x:295, y:60,  pause:300, click:true },
  { x:295, y:60,  pause:700 },
  { x:230, y:198, pause:600, row:0 },
  { x:230, y:198, pause:500, tooltip:'Sarah Johnson — Manager', row:0 },
  { x:230, y:198, pause:300, click:true },
  { x:230, y:198, pause:700 },
  { x:230, y:226, pause:500, row:1 },
  { x:230, y:226, pause:500, tooltip:'James Okafor — On Leave', row:1 },
  { x:230, y:226, pause:400 },
  { x:185, y:60,  pause:400 },
];

let hrWpIdx = 0;
function runHrStep() {
  const wp = hrWaypoints[hrWpIdx % hrWaypoints.length];
  hr.moveTo(wp.x, wp.y);
  if (wp.tooltip) hr.showTooltip(wp.tooltip); else hr.hideTooltip();
  if (wp.click)   setTimeout(() => hr.click(), 200);
  document.querySelectorAll<HTMLElement>('.hr-emp-row').forEach(r => r.style.background = '');
  if (wp.row !== undefined) {
    const row = document.querySelectorAll<HTMLElement>('.hr-emp-row')[wp.row];
    if (row) row.style.background = '#f5f3ff';
  }
  hrWpIdx++;
  setTimeout(runHrStep, wp.pause);
}
setTimeout(runHrStep, 1000);
</script>
