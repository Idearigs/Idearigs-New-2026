                <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-50">
                  <span class="text-xs font-semibold text-gray-700">Employees</span>
                  <span class="text-xs text-violet-600 font-medium">Run Payroll</span>
                </div>
                {[
                  { name: 'Sarah Johnson', role: 'Manager', status: 'Active', avatar: 'SJ' },
                  { name: 'James Okafor', role: 'Developer', status: 'On Leave', avatar: 'JO' },
                  { name: 'Priya Patel', role: 'Designer', status: 'Active', avatar: 'PP' },
                ].map((emp, i) => (
                  <div class={`flex items-center gap-3 px-4 py-2.5 hr-emp-row ${i < 2 ? 'border-b border-gray-50' : ''}`} data-emp={i}>
                    <div class="w-7 h-7 rounded-full bg-violet-100 flex items-center justify-center flex-shrink-0">
                      <span class="text-violet-700 text-xs font-bold">{emp.avatar}</span>
