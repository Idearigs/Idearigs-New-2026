---
import Button from '../ui/Button.astro';
---

<section class="relative pt-32 pb-16 lg:pt-40 lg:pb-24 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-subtle -z-10"></div>

  <!-- Decorative elements -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-accent/5 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary/5 rounded-full blur-3xl -z-10"></div>

  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="animate-on-scroll">
        <span class="badge-accent mb-6">
          Transforming Business Technology
        </span>

        <h1 class="text-balance mb-6">
          Build. Scale.
          <span class="text-accent">Succeed.</span>
        </h1>

        <p class="text-lg md:text-xl text-primary/70 mb-8 max-w-xl">
          From cutting-edge POS systems to powerful digital marketing strategies, we provide the technology solutions that drive your business forward.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <Button href="#contact" variant="primary" size="lg">
            Get Started
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button href="#solutions" variant="secondary" size="lg">
            Explore Solutions
          </Button>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap gap-8">
          <div>
            <p class="text-3xl md:text-4xl font-bold text-primary">500+</p>
            <p class="text-primary/60">Clients Served</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-bold text-primary">98%</p>
            <p class="text-primary/60">Client Satisfaction</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-bold text-primary">10+</p>
            <p class="text-primary/60">Years Experience</p>
          </div>
        </div>
      </div>

      <!-- Floating Mockup -->
      <div class="relative animate-on-scroll animation-delay-200">
        <div class="relative">
          <!-- Main dashboard mockup -->
          <div class="bg-white rounded-2xl shadow-soft-xl p-4 animate-float">
            <div class="aspect-mockup bg-gradient-to-br from-primary/5 to-accent/5 rounded-xl overflow-hidden">
              <!-- Dashboard UI mockup -->
              <div class="p-6 h-full flex flex-col">
                <!-- Top bar -->
                <div class="flex items-center justify-between mb-6">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-primary rounded-lg"></div>
                    <div class="w-24 h-3 bg-primary/20 rounded-full"></div>
                  </div>
                  <div class="flex gap-2">
                    <div class="w-8 h-8 bg-primary/10 rounded-lg"></div>
                    <div class="w-8 h-8 bg-accent rounded-lg"></div>
                  </div>
                </div>

                <!-- Content grid -->
                <div class="grid grid-cols-3 gap-4 mb-6">
                  <div class="bg-white/80 rounded-xl p-4 shadow-sm">
                    <div class="w-6 h-6 bg-pastel-green rounded-lg mb-2"></div>
                    <div class="w-16 h-3 bg-primary/20 rounded-full mb-1"></div>
                    <div class="w-12 h-5 bg-primary rounded-full"></div>
                  </div>
                  <div class="bg-white/80 rounded-xl p-4 shadow-sm">
                    <div class="w-6 h-6 bg-pastel-blue rounded-lg mb-2"></div>
                    <div class="w-16 h-3 bg-primary/20 rounded-full mb-1"></div>
                    <div class="w-12 h-5 bg-accent rounded-full"></div>
                  </div>
                  <div class="bg-white/80 rounded-xl p-4 shadow-sm">
                    <div class="w-6 h-6 bg-pastel-purple rounded-lg mb-2"></div>
                    <div class="w-16 h-3 bg-primary/20 rounded-full mb-1"></div>
                    <div class="w-12 h-5 bg-primary rounded-full"></div>
                  </div>
                </div>

                <!-- Chart placeholder -->
                <div class="flex-1 bg-white/80 rounded-xl p-4 shadow-sm">
                  <div class="flex items-end h-full gap-2 pb-4">
                    {[40, 65, 45, 80, 55, 90, 70].map((height) => (
                      <div class="flex-1 bg-gradient-to-t from-accent to-accent/50 rounded-t-lg" style={`height: ${height}%`}></div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating card 1 -->
          <div class="absolute -left-8 top-1/4 bg-white rounded-xl shadow-soft p-4 animate-float animation-delay-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-pastel-green rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-primary">Sales Updated</p>
                <p class="text-xs text-primary/60">+24% this week</p>
              </div>
            </div>
          </div>

          <!-- Floating card 2 -->
          <div class="absolute -right-4 bottom-1/4 bg-white rounded-xl shadow-soft p-4 animate-float animation-delay-400">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-pastel-purple rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-primary">Revenue</p>
                <p class="text-xs text-primary/60">$12,450 today</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
