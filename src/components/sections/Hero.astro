---
import Button from '../ui/Button.astro';
---

<section class="relative pt-36 pb-12 lg:pt-40 lg:pb-24 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-subtle -z-10"></div>

  <!-- Decorative elements (hidden on mobile to avoid overflow) -->
  <div class="hidden sm:block absolute top-20 left-10 w-72 h-72 bg-accent/5 rounded-full blur-3xl -z-10"></div>
  <div class="hidden sm:block absolute bottom-20 right-10 w-96 h-96 bg-primary/5 rounded-full blur-3xl -z-10"></div>

  <div class="container-custom">
    <div class="grid lg:grid-cols-[1fr_1.3fr] gap-8 lg:gap-16 items-center">
      <!-- Content -->
      <div class="animate-on-scroll text-center lg:text-left">
        <span class="badge-accent mb-5">
          Transforming Business Technology
        </span>

        <h1 class="text-balance mb-5">
          One login.<br class="hidden sm:block"/> One system.<br class="hidden sm:block"/>
          <span style="color:#6366F1;">Total control.</span>
        </h1>

        <p class="text-base md:text-xl text-gray-700 mb-7 max-w-xl mx-auto lg:mx-0">
          From cutting-edge POS systems to powerful digital marketing strategies, we provide the technology solutions that drive your business forward.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-8 justify-center lg:justify-start">
          <Button href="#contact" variant="primary" size="lg">
            Get Started
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button href="#solutions" variant="secondary" size="lg">
            Explore Solutions
          </Button>
        </div>

        <!-- Stats -->
        <div class="flex justify-center lg:justify-start gap-6 sm:gap-8">
          <div>
            <p class="text-2xl md:text-4xl font-bold text-gray-900">500+</p>
            <p class="text-gray-600 text-sm font-medium">Clients Served</p>
          </div>
          <div>
            <p class="text-2xl md:text-4xl font-bold text-gray-900">98%</p>
            <p class="text-gray-600 text-sm font-medium">Client Satisfaction</p>
          </div>
          <div>
            <p class="text-2xl md:text-4xl font-bold text-gray-900">10+</p>
            <p class="text-gray-600 text-sm font-medium">Years Experience</p>
          </div>
        </div>
      </div>

      <!-- POS Mockup — hidden on small mobile, shown from sm up -->
      <div class="relative animate-on-scroll animation-delay-200 hidden sm:block">
        <div class="relative">

          <!-- Browser chrome -->
          <div class="bg-white rounded-2xl shadow-soft-xl overflow-hidden animate-float border border-gray-100">
            <!-- New tag banner -->
            <div class="bg-gradient-to-r from-accent to-indigo-500 px-4 py-1.5 flex items-center justify-center gap-2">
              <span class="bg-white text-accent text-xs font-bold px-2 py-0.5 rounded-full uppercase tracking-wide">New</span>
              <span class="text-white text-xs font-medium">Introducing TrueDesk — Our all-in-one business management platform</span>
              <span class="text-white/70 text-xs">✦</span>
            </div>
            <!-- Browser bar -->
            <div class="bg-gray-50 px-4 py-2.5 flex items-center gap-3 border-b border-gray-100">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 bg-red-400 rounded-full"></div>
                <div class="w-2.5 h-2.5 bg-yellow-400 rounded-full"></div>
                <div class="w-2.5 h-2.5 bg-green-400 rounded-full"></div>
              </div>
              <div class="flex-1 bg-white rounded-md h-5 flex items-center px-3 border border-gray-100">
                <span class="text-xs text-gray-400 font-mono">app.truedesk.co.uk/pos/dashboard</span>
              </div>
            </div>

            <!-- POS UI -->
            <div class="flex" style="height:340px;">
              <!-- Sidebar -->
              <div class="w-36 bg-white border-r border-gray-100 flex flex-col p-3 gap-1 flex-shrink-0">
                <div class="flex items-center gap-2 mb-4 px-1">
                  <div class="w-7 h-7 bg-accent rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                  </div>
                  <span class="text-gray-900 text-xs font-bold">Idearigs POS</span>
                </div>
                {['Dashboard','Point of Sale','Sales','Inventory','Customers','Reports'].map((item, i) => (
                  <div class={`flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium ${i === 0 ? 'bg-accent/10 text-accent font-semibold' : 'text-gray-500'}`}>
                    <div class={`w-1.5 h-1.5 rounded-full ${i === 0 ? 'bg-accent' : 'bg-gray-300'}`}></div>
                    {item}
                  </div>
                ))}
              </div>

              <!-- Main content -->
              <div class="flex-1 bg-gray-50 p-4 overflow-hidden relative">
                <!-- Stats row -->
                <div class="grid grid-cols-3 gap-2 mb-3">
                  {[
                    { label: "Today's Sales", value: '£1,284', change: '+12%', color: 'text-green-600' },
                    { label: 'Transactions',  value: '47',     change: '+5%',  color: 'text-green-600' },
                    { label: 'Avg. Order',    value: '£27.32', change: '-2%',  color: 'text-red-500'   },
                  ].map((s) => (
                    <div class="bg-white rounded-xl p-3 shadow-sm border border-gray-100">
                      <p class="text-gray-400 text-xs mb-1">{s.label}</p>
                      <p class="text-gray-900 font-bold text-base leading-none">{s.value}</p>
                      <p class={`text-xs mt-1 font-medium ${s.color}`}>{s.change}</p>
                    </div>
                  ))}
                </div>

                <!-- Recent sales -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                  <div class="flex items-center justify-between px-4 py-2 border-b border-gray-50">
                    <span class="text-xs font-semibold text-gray-700">Recent Sales</span>
                    <span class="text-xs text-accent font-medium">View all</span>
                  </div>
                  {[
                    { name: 'Hasitha De Silva',  item: 'Gold Ring 9ct',    amount: '£450.00',    time: '2 min ago',  avatar: 'HS' },
                    { name: 'Walk-in Customer',  item: 'Chain Repair',     amount: '£35.00',     time: '14 min ago', avatar: 'WC' },
                    { name: 'Steph Gray-Blest',  item: 'Diamond Cluster',  amount: '£1,200.00',  time: '31 min ago', avatar: 'SG' },
                  ].map((sale, i) => (
                    <div class={`hero-sale-row flex items-center gap-3 px-4 py-2.5 transition-colors duration-200 ${i < 2 ? 'border-b border-gray-50' : ''}`}>
                      <div class="w-7 h-7 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                        <span class="text-accent text-xs font-bold">{sale.avatar}</span>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-xs font-semibold text-gray-800 truncate">{sale.name}</p>
                        <p class="text-xs text-gray-400 truncate">{sale.item}</p>
                      </div>
                      <div class="text-right flex-shrink-0">
                        <p class="text-xs font-bold text-gray-900">{sale.amount}</p>
                        <p class="text-xs text-gray-400">{sale.time}</p>
                      </div>
                    </div>
                  ))}
                </div>
              <!-- Cursor -->
              <div id="hero-cursor" class="absolute pointer-events-none z-20" style="left:180px;top:55px;transition:none;">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M4 2L16 10L10 11L8 17L4 2Z" fill="white" stroke="#374151" stroke-width="1.5"/>
                </svg>
                <div id="hero-tooltip" class="absolute left-5 top-0 bg-gray-900 text-white text-xs px-2 py-1 rounded-lg whitespace-nowrap opacity-0 transition-opacity duration-200 shadow-lg"></div>
              </div>

              </div>
            </div>
          </div>

          <!-- Floating card 1 -->
          <div class="hidden lg:block absolute -left-6 top-1/4 bg-white rounded-xl shadow-soft p-3 animate-float animation-delay-200 border border-gray-100">
            <div class="flex items-center gap-2.5">
              <div class="w-9 h-9 bg-green-50 rounded-xl flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold text-gray-900">Payment Received</p>
                <p class="text-xs text-gray-500">£450.00 · Card</p>
              </div>
            </div>
          </div>

          <!-- Floating card 2 -->
          <div class="hidden lg:block absolute -right-6 bottom-1/4 bg-white rounded-xl shadow-soft p-3 animate-float animation-delay-400 border border-gray-100">
            <div class="flex items-center gap-2.5">
              <div class="w-9 h-9 bg-accent/10 rounded-xl flex items-center justify-center">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold text-gray-900">Revenue</p>
                <p class="text-xs text-gray-500">£1,284 today</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const cursorEl  = document.getElementById('hero-cursor')!;
  const tooltipEl = document.getElementById('hero-tooltip')!;

  if (!cursorEl) return;

  // ── Lerp engine ──────────────────────────────────────────────
  let curX = 180, curY = 55;
  let tgtX = 180, tgtY = 55;

  const ripple = document.createElement('div');
  ripple.style.cssText = `
    position:absolute;width:18px;height:18px;border-radius:50%;
    background:rgba(99,102,241,0.3);transform:scale(0);
    pointer-events:none;z-index:19;margin-left:-4px;margin-top:-4px;
    transition:transform 0.25s ease-out,opacity 0.25s ease-out;
  `;
  cursorEl.appendChild(ripple);

  (function tick() {
    curX += (tgtX - curX) * 0.10;
    curY += (tgtY - curY) * 0.10;
    cursorEl.style.left = curX + 'px';
    cursorEl.style.top  = curY + 'px';
    requestAnimationFrame(tick);
  })();

  function moveTo(x: number, y: number) { tgtX = x; tgtY = y; }

  function click() {
    const svg = cursorEl.querySelector('svg') as SVGElement;
    if (svg) { svg.style.transform = 'scale(0.82)'; svg.style.transition = 'transform 0.1s'; }
    ripple.style.transform = 'scale(1.6)'; ripple.style.opacity = '1';
    setTimeout(() => {
      if (svg) svg.style.transform = 'scale(1)';
      ripple.style.transform = 'scale(0)'; ripple.style.opacity = '0';
    }, 220);
  }

  function showTip(t: string) { tooltipEl.textContent = t; tooltipEl.style.opacity = '1'; }
  function hideTip()           { tooltipEl.style.opacity = '0'; }

  // ── Waypoints ────────────────────────────────────────────────
  const waypoints = [
    { x:190, y:55,  pause:700 },
    { x:190, y:55,  pause:500, tip:"Today's Sales · £1,284" },
    { x:190, y:55,  pause:300, click:true },
    { x:190, y:55,  pause:800 },
    { x:310, y:55,  pause:600 },
    { x:310, y:55,  pause:500, tip:'Transactions · 47' },
    { x:310, y:55,  pause:300, click:true },
    { x:310, y:55,  pause:800 },
    { x:380, y:55,  pause:500 },
    { x:380, y:55,  pause:500, tip:'Avg. Order · £27.32' },
    { x:380, y:55,  pause:300, click:true },
    { x:380, y:55,  pause:700 },
    { x:230, y:185, pause:700, row:0 },
    { x:230, y:185, pause:500, tip:'Hasitha De Silva · £450.00', row:0 },
    { x:230, y:185, pause:350, click:true, row:0 },
    { x:230, y:185, pause:800, row:0 },
    { x:230, y:215, pause:600, row:1 },
    { x:230, y:215, pause:500, tip:'Walk-in Customer · £35.00', row:1 },
    { x:230, y:215, pause:350, click:true, row:1 },
    { x:230, y:215, pause:700, row:1 },
    { x:230, y:245, pause:600, row:2 },
    { x:230, y:245, pause:500, tip:'Steph Gray-Blest · £1,200.00', row:2 },
    { x:230, y:245, pause:400, row:2 },
    { x:190, y:55,  pause:500 },
  ];

  let idx = 0;
  function step() {
    const wp = waypoints[idx % waypoints.length];
    moveTo(wp.x, wp.y);
    if (wp.tip)   showTip(wp.tip); else hideTip();
    if (wp.click) setTimeout(click, 200);

    // row highlight
    document.querySelectorAll<HTMLElement>('.hero-sale-row').forEach(r => r.style.background = '');
    if (wp.row !== undefined) {
      const row = document.querySelectorAll<HTMLElement>('.hero-sale-row')[wp.row];
      if (row) row.style.background = '#f0f9ff';
    }

    idx++;
    setTimeout(step, wp.pause);
  }

  setTimeout(step, 1000);
})();
</script>
