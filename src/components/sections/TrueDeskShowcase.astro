                  { name:'Sophie Brennan',   role:'Sales Associate',   salary:'£1,800/mo', status:'On Leave', statusColor:'#f97316', init:'SB', bg:'#ec4899' },
                  { name:'Tom Wright',       role:'Repair Technician', salary:'£2,100/mo', status:'Active',   statusColor:'#10b981', init:'TW', bg:'#f97316' },
                  { name:'Emma Kowalski',    role:'Administrator',     salary:'£1,700/mo', status:'Active',   statusColor:'#10b981', init:'EK', bg:'#3b82f6' },
                ].map(e => (
                  <div class="hr-employee-row flex items-center gap-4 bg-white rounded-2xl px-4 py-3 border border-gray-100 cursor-pointer hover:border-violet-200 hover:shadow-md active:scale-[0.99] transition-all"
                    onclick="this.classList.toggle('selected');this.style.background=this.classList.contains('selected')?'#f5f3ff':'';this.style.borderColor=this.classList.contains('selected')?'#c4b5fd':'#f3f4f6';"
                  >
                    <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-white text-xs font-bold" style={`background:${e.bg};`}>{e.init}</div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-800">{e.name}</p>
                      <p class="text-xs text-gray-400">{e.role}</p>
                    </div>
                    <p class="text-xs font-semibold text-gray-600 flex-shrink-0">{e.salary}</p>
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0" style={`color:${e.statusColor};background:${e.statusColor}18;`}>{e.status}</span>
                    <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </div>
                ))}
              </div>
            </div>

            <!-- ═══ ANALYTICS ═══ -->
            <div class="td-view absolute inset-0 p-5 overflow-hidden" data-view="analytics" style="opacity:0;pointer-events:none;">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-bold text-gray-900">Analytics</h3>
                  <p class="text-xs text-gray-400 mt-0.5">Sales performance overview</p>
                </div>
                <div class="flex gap-1" id="analytics-range">
                  {[['Today','#f59e0b'],['7 Days','#f59e0b'],['30 Days','#f59e0b'],['12 Mo','#f59e0b']].map(([r,c],i) => (
                    <button class="analytics-range-btn text-xs px-3 py-1.5 rounded-lg font-semibold transition-all cursor-pointer" style={i===2?`background:#f59e0b;color:white`:'background:#f3f4f6;color:#6b7280'} data-idx={i} data-color={c}>{r}</button>
                  ))}
                </div>
              </div>
              <div class="grid grid-cols-5 gap-4 mb-4">
                <div class="col-span-3 rounded-2xl p-4 border border-amber-100" style="background:#fffbeb;">
                  <div class="flex items-end justify-between mb-3">
                    <div>
                      <p class="text-xs font-medium mb-1" style="color:#92400e;" id="analytics-period-label">Total Revenue — 30 Days</p>
                      <p class="text-3xl font-black text-gray-900" id="analytics-revenue">£18,340</p>
                      <p class="text-xs font-semibold text-emerald-600 mt-1" id="analytics-change">+23% vs last period</p>
                    </div>
                    <button class="text-xs px-2.5 py-1.5 rounded-lg font-semibold text-white hover:opacity-90 active:scale-95 transition-all" style="background:#f59e0b;">Export CSV</button>
                  </div>
                  <div class="flex items-end gap-1 h-24" id="analytics-bars">
                    {[38,45,52,41,63,55,78,66,81,74,89,83,91,100].map((h) => (
                      <div class="flex-1 rounded-t-sm cursor-pointer hover:opacity-100 opacity-80 transition-opacity" style={`height:${h}%;background:linear-gradient(to top,#f59e0b,#fcd34d);`}></div>
                    ))}
                  </div>
                </div>
                <div class="col-span-2 bg-gray-50 rounded-2xl p-4 border border-gray-100">
                  <p class="text-sm font-bold text-gray-800 mb-3">Top Products</p>
                  {[
                    { name:'Gold Ring 9ct',    revenue:'£4,200', pct:73 },
                    { name:'Diamond Cluster',  revenue:'£3,600', pct:62 },
                    { name:'Silver Bracelet',  revenue:'£2,550', pct:44 },
                    { name:'Chain Repair',     revenue:'£1,890', pct:32 },
                  ].map(p => (
                    <div class="mb-3 last:mb-0 group cursor-pointer">
                      <div class="flex justify-between mb-1">
                        <p class="text-xs font-medium text-gray-700 truncate flex-1 pr-2 group-hover:text-amber-600 transition-colors">{p.name}</p>
                        <p class="text-xs font-bold text-gray-900 flex-shrink-0">{p.revenue}</p>
                      </div>
                      <div class="bg-gray-200 rounded-full h-1.5">
                        <div class="h-1.5 rounded-full transition-all duration-300 group-hover:opacity-80" style={`width:${p.pct}%;background:linear-gradient(to right,#f59e0b,#fcd34d);`}></div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center td-reveal td-delay-3">
      <p class="text-gray-500 text-sm mb-2 font-medium">One subscription &middot; No setup fees &middot; Cancel anytime</p>
      <p class="text-gray-400 text-xs mb-8">Includes a complimentary 1-month trial — no commitment required.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl font-bold text-white text-base transition-all duration-300 hover:scale-105 hover:shadow-xl"
          style="background:linear-gradient(135deg,#6366f1,#06b6d4);box-shadow:0 4px 24px rgba(99,102,241,0.28);">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Contact Us for a Free Trial
        </a>
        <a href="https://truedesk.co.uk" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl font-semibold text-gray-600 border border-gray-200 text-base hover:bg-gray-50 transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Explore TrueDesk
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .td-view { transition: opacity 0.3s ease; }
  .td-reveal { opacity:0; transform:translateY(24px); transition:opacity 0.65s ease,transform 0.65s ease; }
  .td-reveal.in-view { opacity:1; transform:translateY(0); }
  .td-delay-1 { transition-delay:0.08s; }
  .td-delay-2 { transition-delay:0.18s; }
  .td-delay-3 { transition-delay:0.3s; }
  .td-tile { transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease; }
  .td-tile:hover .td-tile-glow { opacity: 1; }
</style>

<script>
(function(){
  const urlMap: Record<string,string> = {
    dashboard: 'app.truedesk.co.uk/dashboard',
    pos:       'app.truedesk.co.uk/pos',
    repairs:   'app.truedesk.co.uk/repairs',
    hr:        'app.truedesk.co.uk/hr-payroll',
    analytics: 'app.truedesk.co.uk/analytics',
  };

  // ── View switcher ──
  function switchView(viewId: string, sIdx: number, color: string) {
    document.querySelectorAll<HTMLElement>('.td-view').forEach(v => {
      v.style.opacity = '0'; v.style.pointerEvents = 'none';
    });
    const el = document.querySelector<HTMLElement>(`.td-view[data-view="${viewId}"]`);
    if (el) { el.style.opacity = '1'; el.style.pointerEvents = ''; }

    document.querySelectorAll<HTMLElement>('.td-sidebar-item').forEach((item, i) => {
      const icon = item.querySelector<SVGElement>('.td-sidebar-icon');
      if (i === sIdx) {
        item.style.cssText = `background:${color}14;color:${color};font-weight:600;`;
        if (icon) icon.style.color = color;
      } else {
        item.style.cssText = '';
        if (icon) icon.style.color = '#9ca3af';
      }
    });

    document.querySelectorAll<HTMLElement>('.td-tile').forEach(tile => {
      const isActive = tile.dataset.view === viewId;
      const tColor   = tile.dataset.color || '#6366f1';
      const tBg      = tile.dataset.bg    || '';
      const tBorder  = tile.dataset.border|| '';
      const glow     = tile.querySelector<HTMLElement>('.td-tile-glow');
      if (isActive) {
        tile.style.background    = tBg;
        tile.style.borderColor   = tColor;
        tile.style.transform     = 'translateY(-4px)';
        tile.style.boxShadow     = `0 12px 28px ${tColor}30`;
        if (glow) glow.style.opacity = '1';
      } else {
        tile.style.background    = 'rgba(255,255,255,0.55)';
        tile.style.borderColor   = 'rgba(255,255,255,0.7)';
        tile.style.transform     = '';
        tile.style.boxShadow     = '0 2px 12px rgba(0,0,0,0.06),inset 0 1px 0 rgba(255,255,255,0.8)';
        if (glow) glow.style.opacity = '0';
      }
    });

    const urlBar = document.getElementById('td-url-bar');
    if (urlBar) urlBar.textContent = urlMap[viewId] || 'app.truedesk.co.uk';

    // ── Mobile views ──
    document.querySelectorAll<HTMLElement>('.mobile-td-view').forEach(v => {
      v.style.opacity = '0'; v.style.pointerEvents = 'none';
    });
    const mEl = document.querySelector<HTMLElement>(`.mobile-td-view[data-view="${viewId}"]`);
    if (mEl) { mEl.style.opacity = '1'; mEl.style.pointerEvents = ''; }

    document.querySelectorAll<HTMLElement>('.mobile-tab-btn').forEach(btn => {
      const active = btn.dataset.view === viewId;
      const c = btn.dataset.color || '#6366f1';
      const ico = btn.querySelector<SVGElement>('svg');
      const lbl = btn.querySelector<HTMLElement>('span');
      btn.style.background = active ? `${c}18` : '';
      if (ico) ico.style.color = active ? c : '#9ca3af';
      if (lbl) { lbl.style.color = active ? c : '#9ca3af'; lbl.style.fontWeight = active ? '700' : '600'; }
    });

    const mUrlBar = document.getElementById('mobile-url-bar');
    if (mUrlBar) mUrlBar.textContent = viewId;
  }

  // ── Tile clicks ──
  const tileDefs = Array.from(document.querySelectorAll<HTMLElement>('.td-tile')).map(t => ({
    id: t.dataset.view!, sIdx: parseInt(t.dataset.sidx!), color: t.dataset.color!
  }));
  const cycleList = tileDefs.filter((t,i,a) => a.findIndex(x=>x.id===t.id)===i);
  let cycleIdx = 0;
  let timer: ReturnType<typeof setInterval>;

  function startAuto() {
    timer = setInterval(() => {
      cycleIdx = (cycleIdx+1) % cycleList.length;
      const t = cycleList[cycleIdx];
      switchView(t.id, t.sIdx, t.color);
    }, 4000);
  }
  function stopAuto() { clearInterval(timer); }

  document.querySelectorAll<HTMLElement>('.td-tile').forEach(tile => {
    tile.addEventListener('click', () => {
      const id    = tile.dataset.view!;
      const sIdx  = parseInt(tile.dataset.sidx!);
      const color = tile.dataset.color!;
      cycleIdx = cycleList.findIndex(t=>t.id===id);
      switchView(id, sIdx, color);
      stopAuto();
    });
  });

  // ── Sidebar nav click ──
  document.querySelectorAll<HTMLElement>('.td-sidebar-item').forEach((item, i) => {
    item.addEventListener('click', () => {
      const viewId = item.dataset.view || 'dashboard';
      const color  = item.dataset.color || '#6366f1';
      const def    = cycleList.find(t => t.id === viewId);
      const sIdx   = def ? def.sIdx : i;
      if (def) cycleIdx = cycleList.indexOf(def);
      switchView(viewId, i, color);
      stopAuto();
    });
  });

  const wrap = document.getElementById('td-mockup-wrap');
  if (wrap) { wrap.addEventListener('mouseenter', stopAuto); wrap.addEventListener('mouseleave', startAuto); }

  // ── Mobile tab nav clicks ──
  document.querySelectorAll<HTMLElement>('.mobile-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id    = btn.dataset.view!;
      const color = btn.dataset.color || '#6366f1';
      const def   = cycleList.find(t => t.id === id);
      const sIdx  = def ? def.sIdx : 0;
      if (def) cycleIdx = cycleList.indexOf(def);
      switchView(id, sIdx, color);
      stopAuto();
    });
  });

  // ── POS interactions ──
  interface CartItem { name: string; price: number; qty: number }
  let cart: CartItem[] = [];

  function renderCart() {
    const cartEl = document.getElementById('pos-cart-items');
    const subEl  = document.getElementById('pos-subtotal');
    const taxEl  = document.getElementById('pos-tax');
    const totEl  = document.getElementById('pos-total');
    const chargeBtn = document.getElementById('pos-charge-btn');
    if (!cartEl) return;
    if (cart.length === 0) {
      cartEl.innerHTML = '<p class="text-xs text-gray-400 text-center mt-6 italic">Click a product to add</p>';
    } else {
      cartEl.innerHTML = cart.map((item,i) => `
        <div class="bg-white rounded-xl p-2.5 border border-gray-100 shadow-sm flex flex-col gap-1">
          <div class="flex justify-between items-start gap-1">
            <p class="text-xs font-semibold text-gray-800 flex-1 leading-snug">${item.name}</p>
            <button class="cart-remove text-gray-300 hover:text-red-400 transition-colors text-base leading-none flex-shrink-0" data-idx="${i}">×</button>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1">
              <button class="cart-qty w-5 h-5 rounded bg-gray-100 text-xs font-bold hover:bg-gray-200 active:scale-95 transition-all" data-idx="${i}" data-delta="-1">−</button>
              <span class="text-xs text-gray-600 font-medium w-5 text-center">${item.qty}</span>
              <button class="cart-qty w-5 h-5 rounded bg-gray-100 text-xs font-bold hover:bg-gray-200 active:scale-95 transition-all" data-idx="${i}" data-delta="1">+</button>
            </div>
            <p class="text-xs font-bold text-gray-900">£${(item.price*item.qty).toFixed(2)}</p>
          </div>
        </div>
      `).join('');

      cartEl.querySelectorAll('.cart-remove').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx = parseInt((e.currentTarget as HTMLElement).dataset.idx!);
          cart.splice(idx,1); renderCart();
        });
      });
      cartEl.querySelectorAll('.cart-qty').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx   = parseInt((e.currentTarget as HTMLElement).dataset.idx!);
          const delta = parseInt((e.currentTarget as HTMLElement).dataset.delta!);
          cart[idx].qty = Math.max(1, cart[idx].qty + delta);
          renderCart();
        });
      });
    }
    const subtotal = cart.reduce((s,i) => s + i.price*i.qty, 0);
    const tax = subtotal * 0.2;
    const total = subtotal + tax;
    if (subEl) subEl.textContent = `£${subtotal.toFixed(2)}`;
    if (taxEl) taxEl.textContent = `£${tax.toFixed(2)}`;
    if (totEl) totEl.textContent = `£${total.toFixed(2)}`;
    if (chargeBtn) chargeBtn.textContent = `Charge £${total.toFixed(2)}`;
  }

  function showToast(msg: string) {
    const toast = document.getElementById('pos-toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 1500);
  }

  document.querySelectorAll<HTMLElement>('.pos-product-card').forEach(card => {
    card.addEventListener('click', () => {
      const name  = card.dataset.name!;
      const price = parseFloat(card.dataset.price!);
      const existing = cart.find(i => i.name === name);
      if (existing) { existing.qty++; } else { cart.push({ name, price, qty: 1 }); }
      renderCart();
      showToast(`Added: ${name}`);
    });
  });

  document.getElementById('pos-clear-btn')?.addEventListener('click', () => { cart = []; renderCart(); });

  document.getElementById('pos-charge-btn')?.addEventListener('click', () => {
    if (cart.length === 0) return;
    const btn = document.getElementById('pos-charge-btn')!;
    btn.textContent = '✓ Payment Complete';
    btn.style.background = '#6366f1';
    setTimeout(() => { cart = []; renderCart(); btn.style.background = '#10b981'; }, 2000);
  });

  // POS category filter
  document.querySelectorAll('.pos-cat-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('.pos-cat-tab').forEach(t => {
        (t as HTMLElement).style.cssText = 'background:#f3f4f6;color:#4b5563';
      });
      (tab as HTMLElement).style.cssText = 'background:#10b981;color:white';
      const cat = (tab as HTMLElement).dataset.cat;
      document.querySelectorAll<HTMLElement>('.pos-product-card').forEach(card => {
        card.style.display = (cat === 'All' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });

  // ── Repair status tabs ──
  document.querySelectorAll('.repair-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const status = (tab as HTMLElement).dataset.status!;
      const color  = (tab as HTMLElement).dataset.color!;
      document.querySelectorAll<HTMLElement>('.repair-tab').forEach(t => {
        t.style.cssText = 'background:#f9fafb;border-color:#e5e7eb;color:#6b7280';
      });
      (tab as HTMLElement).style.cssText = `background:${color}15;border-color:${color}40;color:${color}`;

      document.querySelectorAll<HTMLElement>('.repair-row').forEach(row => {
        const show = status === 'All' || row.dataset.status === status;
        row.style.display = show ? '' : 'none';
      });

      const visible = document.querySelectorAll<HTMLElement>('.repair-row:not([style*="none"])').length;
      const countEl = document.getElementById('repair-count');
      if (countEl) countEl.textContent = `${visible} job${visible!==1?'s':''}`;
    });
  });

  // ── Analytics range buttons ──
  const analyticsData: Record<number,{label:string,revenue:string,change:string,bars:number[]}> = {
    0: { label:"Today's Revenue",    revenue:'£840',  change:'+5% vs yesterday', bars:[20,45,30,60,40,75,55,80,65,90,70,95,60,100] },
    1: { label:"Revenue — 7 Days",  revenue:'£4,280', change:'+12% vs last week', bars:[40,55,48,72,60,85,92,78,65,88,74,95,82,100] },
    2: { label:"Revenue — 30 Days", revenue:'£18,340',change:'+23% vs last period', bars:[38,45,52,41,63,55,78,66,81,74,89,83,91,100] },
    3: { label:"Revenue — 12 Mo",   revenue:'£198,500',change:'+31% vs last year', bars:[45,50,60,55,70,65,80,75,82,88,90,100,88,95] },
  };

  document.querySelectorAll('.analytics-range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt((btn as HTMLElement).dataset.idx!);
      document.querySelectorAll<HTMLElement>('.analytics-range-btn').forEach(b => {
        b.style.cssText = 'background:#f3f4f6;color:#6b7280';
      });
      (btn as HTMLElement).style.cssText = 'background:#f59e0b;color:white';
      const d = analyticsData[idx];
      const labelEl   = document.getElementById('analytics-period-label');
      const revEl     = document.getElementById('analytics-revenue');
      const changeEl  = document.getElementById('analytics-change');
      const barsEl    = document.getElementById('analytics-bars');
      if (labelEl)  labelEl.textContent  = d.label;
      if (revEl)    revEl.textContent    = d.revenue;
      if (changeEl) changeEl.textContent = d.change;
      if (barsEl) {
        barsEl.innerHTML = d.bars.map(h => `<div class="flex-1 rounded-t-sm cursor-pointer hover:opacity-100 opacity-80 transition-all duration-500" style="height:${h}%;background:linear-gradient(to top,#f59e0b,#fcd34d);"></div>`).join('');
      }
    });
  });

  // ── Dashboard activity rows ──
  document.querySelectorAll('.td-activity-row').forEach(row => {
    row.addEventListener('click', () => {
      const dot  = row.querySelector<HTMLElement>('.td-activity-dot');
      const text = row.querySelector<HTMLElement>('.td-activity-text');
      if (dot) dot.style.background = '#9ca3af';
      if (text) text.style.opacity = '0.5';
      (row as HTMLElement).style.opacity = '0.6';
    });
  });

  // ── Scroll reveal ──
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.td-reveal').forEach(el => obs.observe(el));

  // Init
  switchView('dashboard', 0, '#6366f1');
  startAuto();
})();
</script>
