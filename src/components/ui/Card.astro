---
interface Props {
  variant?: 'default' | 'pastel-green' | 'pastel-blue' | 'pastel-purple' | 'pastel-pink' | 'pastel-yellow' | 'pastel-orange';
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  variant = 'default',
  hover = true,
  padding = 'md',
  class: className = ''
} = Astro.props;

const baseStyles = 'rounded-xl transition-all duration-300 ease-smooth';

const variants = {
  default: 'bg-white shadow-card',
  'pastel-green': 'bg-pastel-green',
  'pastel-blue': 'bg-pastel-blue',
  'pastel-purple': 'bg-pastel-purple',
  'pastel-pink': 'bg-pastel-pink',
  'pastel-yellow': 'bg-pastel-yellow',
  'pastel-orange': 'bg-pastel-orange'
};

const paddings = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const hoverStyles = hover ? 'hover:shadow-card-hover hover:-translate-y-1' : '';

const classes = [
  baseStyles,
  variants[variant],
  paddings[padding],
  hoverStyles,
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
