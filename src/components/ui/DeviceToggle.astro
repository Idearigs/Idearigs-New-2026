---
interface Props {
  defaultDevice?: 'desktop' | 'tablet' | 'mobile';
  class?: string;
}

const { defaultDevice = 'desktop', class: className = '' } = Astro.props;
---

<div class={`inline-flex items-center bg-white rounded-xl p-1 shadow-card ${className}`}>
  <button
    data-device="desktop"
    class={`device-btn flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${defaultDevice === 'desktop' ? 'bg-primary text-white' : 'text-primary/60 hover:text-primary'}`}
    aria-label="Desktop view"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    <span class="hidden sm:inline">Desktop</span>
  </button>

  <button
    data-device="tablet"
    class={`device-btn flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${defaultDevice === 'tablet' ? 'bg-primary text-white' : 'text-primary/60 hover:text-primary'}`}
    aria-label="Tablet view"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
    </svg>
    <span class="hidden sm:inline">Tablet</span>
  </button>

  <button
    data-device="mobile"
    class={`device-btn flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${defaultDevice === 'mobile' ? 'bg-primary text-white' : 'text-primary/60 hover:text-primary'}`}
    aria-label="Mobile view"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
    </svg>
    <span class="hidden sm:inline">Mobile</span>
  </button>
</div>

<script>
  const deviceButtons = document.querySelectorAll('.device-btn');
  const mockupContainers = document.querySelectorAll('[data-mockup]');

  deviceButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const device = btn.getAttribute('data-device');

      // Update button styles
      deviceButtons.forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('text-primary/60', 'hover:text-primary');
      });
      btn.classList.remove('text-primary/60', 'hover:text-primary');
      btn.classList.add('bg-primary', 'text-white');

      // Update mockup display
      mockupContainers.forEach(container => {
        container.setAttribute('data-active-device', device || 'desktop');
      });
    });
  });
</script>
