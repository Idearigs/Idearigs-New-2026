---
interface Props {
  title?: string;
  class?: string;
}

const { title = 'Technologies & services we work with', class: className = '' } = Astro.props;

const techs = [
  { name: 'Stripe',      src: 'https://cdn.simpleicons.org/stripe/635BFF' },
  { name: 'React',       src: 'https://cdn.simpleicons.org/react/61DAFB' },
  { name: 'Node.js',     src: 'https://cdn.simpleicons.org/nodedotjs/339933' },
  { name: 'AWS',         src: '/aws-logo.png' },
  { name: 'Next.js',     src: 'https://cdn.simpleicons.org/nextdotjs/000000' },
  { name: 'TypeScript',  src: 'https://cdn.simpleicons.org/typescript/3178C6' },
  { name: 'Docker',      src: 'https://cdn.simpleicons.org/docker/2496ED' },
  { name: 'MongoDB',     src: 'https://cdn.simpleicons.org/mongodb/47A248' },
  { name: 'Vercel',      src: 'https://cdn.simpleicons.org/vercel/000000' },
  { name: 'GraphQL',     src: 'https://cdn.simpleicons.org/graphql/E10098' },
  { name: 'Tailwind CSS',src: 'https://cdn.simpleicons.org/tailwindcss/06B6D4' },
  { name: 'PostgreSQL',  src: 'https://cdn.simpleicons.org/postgresql/336791' },
  { name: 'Shopify',     src: 'https://cdn.simpleicons.org/shopify/96BF48' },
  { name: 'WordPress',   src: 'https://cdn.simpleicons.org/wordpress/21759B' },
];
---

<div class={`py-8 md:py-12 bg-white border-y border-primary/5 ${className}`}>
  <div class="container-custom">
    {title && (
      <p class="text-center text-xs font-semibold text-gray-500 uppercase tracking-widest mb-6 md:mb-10">
        {title}
      </p>
    )}

    <div class="relative overflow-hidden">
      <!-- Gradient masks -->
      <div class="absolute left-0 top-0 bottom-0 w-8 md:w-24 bg-gradient-to-r from-white to-transparent z-10"></div>
      <div class="absolute right-0 top-0 bottom-0 w-8 md:w-24 bg-gradient-to-l from-white to-transparent z-10"></div>

      <!-- Ticker -->
      <div class="flex animate-ticker items-center">
        {[...techs, ...techs].map((tech) => (
          <div class="flex-shrink-0 mx-5 md:mx-10 flex flex-col items-center gap-1.5">
            <img
              src={tech.src}
              alt={tech.name}
              class="h-6 w-6 md:h-8 md:w-8 object-contain"
              loading="lazy"
            />
            <span class="text-xs font-medium text-gray-600 whitespace-nowrap">{tech.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .animate-ticker {
      animation: none;
    }
  }
</style>
