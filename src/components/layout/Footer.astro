---
const currentYear = new Date().getFullYear();

const services = [
  { label: 'POS & TrueDesk',              href: '/pos-systems' },
  { label: 'Web Development',              href: '/web-development' },
  { label: 'Digital Marketing',            href: '/digital-marketing' },
  { label: 'Business Process Automation',  href: '/contact' },
  { label: 'IT Infrastructure & Cloud',    href: '/server-management' },
  { label: 'Cybersecurity & Compliance',   href: '/contact' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Contact',  href: '#contact' },
  { label: 'Careers',  href: '/careers' },
  { label: 'Blog',     href: '/blog' },
];

const legal = [
  { label: 'Privacy Policy',   href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'Cookie Policy',    href: '/cookies' },
];

const socials = [
  { label: 'LinkedIn',   href: '#', d: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z' },
  { label: 'X/Twitter',  href: '#', d: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { label: 'Facebook',   href: '#', d: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { label: 'Instagram',  href: '#', d: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
];
---

<footer class="bg-[#FCFBFA] border-t border-gray-100">

  <div class="container-custom pt-16 pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Brand col -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <a href="/" class="inline-flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#046645,#059669);">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div>
            <span class="text-lg font-black text-gray-900 tracking-tight">Idearigs</span>
            <p class="text-xs text-gray-400 leading-none">Technology Solutions</p>
          </div>
        </a>

        <p class="text-sm text-gray-500 leading-relaxed mb-6 max-w-xs">
          Helping UK businesses grow through smart technology — from retail systems and web platforms to digital marketing and IT infrastructure.
        </p>

        <!-- Socials -->
        <div class="flex gap-2 mb-8">
          {socials.map(s => (
            <a href={s.href} aria-label={s.label}
              class="w-8 h-8 rounded-lg bg-white border border-gray-200 flex items-center justify-center hover:border-gray-300 hover:shadow-sm transition-all duration-200">
              <svg class="w-3.5 h-3.5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                <path d={s.d}/>
              </svg>
            </a>
          ))}
        </div>

        <!-- TrueDesk mini card -->
        <div class="rounded-2xl p-4 border border-gray-100 bg-white" style="box-shadow:0 2px 12px rgba(0,0,0,0.05);">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-6 h-6 rounded-lg flex items-center justify-center" style="background:linear-gradient(135deg,#6366f1,#06b6d4);">
              <span class="text-white text-xs font-black">T</span>
            </div>
            <span class="text-sm font-bold text-gray-900">TrueDesk</span>
            <span class="text-xs font-bold px-2 py-0.5 rounded-full text-white" style="background:#10b981;">NEW</span>
          </div>
          <p class="text-xs text-gray-400 leading-relaxed mb-3">All-in-one platform — POS, HR, payroll, repairs & analytics.</p>
          <a href="https://truedesk.co.uk" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-white px-3 py-1.5 rounded-lg hover:opacity-90 transition-opacity"
            style="background:linear-gradient(135deg,#046645,#059669);">
            Explore TrueDesk
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="lg:col-span-3 grid grid-cols-2 sm:grid-cols-3 gap-8">

        <!-- Services -->
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Services</p>
          <ul class="space-y-3">
            {services.map(l => (
              <li>
                <a href={l.href} class="text-sm text-gray-500 hover:text-gray-900 transition-colors duration-200">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Company</p>
          <ul class="space-y-3">
            {company.map(l => (
              <li>
                <a href={l.href} class="text-sm text-gray-500 hover:text-gray-900 transition-colors duration-200">{l.label}</a>
              </li>
            ))}
          </ul>

          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 mt-8">Legal</p>
          <ul class="space-y-3">
            {legal.map(l => (
              <li>
                <a href={l.href} class="text-sm text-gray-500 hover:text-gray-900 transition-colors duration-200">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact info -->
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Contact</p>
          <div class="space-y-3">
            <a href="tel:+441234567890" class="flex items-start gap-2.5 group">
              <div class="w-7 h-7 rounded-lg bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5 group-hover:border-accent/30 transition-colors shadow-sm">
                <svg class="w-3.5 h-3.5 text-gray-400 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400">Phone</p>
                <p class="text-sm font-medium text-gray-700 group-hover:text-gray-900 transition-colors">+44 (0) 123 456 7890</p>
              </div>
            </a>
            <a href="mailto:hello@idearigs.com" class="flex items-start gap-2.5 group">
              <div class="w-7 h-7 rounded-lg bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5 group-hover:border-accent/30 transition-colors shadow-sm">
                <svg class="w-3.5 h-3.5 text-gray-400 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400">Email</p>
                <p class="text-sm font-medium text-gray-700 group-hover:text-gray-900 transition-colors">hello@idearigs.com</p>
              </div>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-100">
    <div class="container-custom py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-gray-400">&copy; {currentYear} Idearigs Ltd. All rights reserved.</p>
      <div class="flex items-center gap-5">
        {legal.map(l => (
          <a href={l.href} class="text-xs text-gray-400 hover:text-gray-600 transition-colors">{l.label}</a>
        ))}
      </div>
    </div>
  </div>

</footer>
