---
interface Link {
  label: string;
  href: string;
  description: string;
}

interface Category {
  category: string;
  links: Link[];
}

interface Props {
  items: Category[];
}

const { items } = Astro.props;
---

<div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
  <div class="bg-white rounded-2xl shadow-soft-lg border border-primary/5 p-6 min-w-[500px]">
    <div class="grid grid-cols-2 gap-6">
      {items.map((category) => (
        <div>
          <p class="text-xs font-semibold text-gray-900/40 uppercase tracking-wider mb-4">
            {category.category}
          </p>
          <div class="space-y-1">
            {category.links.map((link) => (
              <a
                href={link.href}
                class="block p-3 rounded-xl hover:bg-background transition-colors duration-200 group/link"
              >
                <p class="font-medium text-gray-900 group-hover/link:text-accent transition-colors">
                  {link.label}
                </p>
                <p class="text-sm text-gray-500 mt-0.5">
                  {link.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Featured CTA -->
    <div class="mt-6 pt-6 border-t border-primary/10">
      <div class="flex items-center justify-between p-4 bg-pastel-purple rounded-xl">
        <div>
          <p class="font-medium text-gray-900">Ready to transform your business?</p>
          <p class="text-sm text-gray-600">Schedule a free consultation today.</p>
        </div>
        <a href="#contact" class="btn-accent text-sm">
          Book a Call
        </a>
      </div>
    </div>
  </div>
</div>
