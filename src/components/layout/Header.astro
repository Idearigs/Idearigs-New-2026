---
import MegaMenu from './MegaMenu.astro';

const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'Solutions',
    href: '#',
    megaMenu: true,
    items: [
      {
        category: 'Products',
        links: [
          { label: 'POS Systems', href: '/pos-systems', description: 'Complete point of sale solutions' },
          { label: 'Enterprise Software', href: '/enterprise', description: 'Custom business applications' },
          { label: 'Cloud Solutions', href: '/cloud', description: 'Scalable cloud infrastructure' }
        ]
      },
      {
        category: 'Services',
        links: [
          { label: 'Web Development', href: '/web-development', description: 'Modern web applications' },
          { label: 'Server Management', href: '/server-management', description: 'Managed server & hosting' },
          { label: 'Digital Marketing', href: '/digital-marketing', description: 'Growth-focused strategies' },
          { label: 'Consulting', href: '/consulting', description: 'Expert business guidance' }
        ]
      }
    ]
  },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '#contact' }
];
---

<!-- Announcement Banner -->
<div id="announcement-banner" class="fixed left-0 right-0 z-[60] flex items-center justify-center px-4 py-2.5 text-sm font-medium transition-transform duration-300" style="top:0;background:linear-gradient(90deg,#e0f2fe,#d1fae5,#ede9fe);">
  <div class="flex items-center gap-2.5 text-gray-800">
    <span class="inline-flex items-center gap-1.5 bg-white/60 border border-white/80 backdrop-blur-sm px-2.5 py-0.5 rounded-full text-xs font-bold" style="color:#046645;">
      <span class="w-1.5 h-1.5 rounded-full animate-pulse inline-block" style="background:#10b981;"></span>
      NEW
    </span>
    <span>One platform for your <span style="color:#6366F1;font-weight:700;">entire business.</span></span>
    <span class="hidden sm:inline text-gray-400">|</span>
    <a href="https://truedesk.co.uk" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex items-center gap-1 font-semibold hover:underline transition-all" style="color:#046645;">
      Explore now
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
  <button id="close-banner" aria-label="Dismiss" class="absolute right-4 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full hover:bg-black/8 transition-colors text-gray-500 hover:text-gray-800">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>

<header
  id="main-header"
  class="fixed left-0 right-0 z-50 transition-all duration-300"
  style="top:var(--banner-height,44px);"
>

  <div class="container-custom">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center group-hover:scale-105 transition-transform duration-300">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
        </div>
        <span class="text-xl font-bold text-gray-900">Idearigs</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          item.megaMenu ? (
            <div class="relative group">
              <button class="flex items-center gap-1 text-gray-800 hover:text-gray-950 transition-colors duration-200 py-2">
                {item.label}
                <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <MegaMenu items={item.items} />
            </div>
          ) : (
            <a href={item.href} class="text-gray-800 hover:text-gray-950 font-semibold transition-colors duration-200">
              {item.label}
            </a>
          )
        ))}
      </div>

      <!-- CTA Button -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="#contact" class="btn-primary">
          Get Started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-900 hover:bg-primary/5 rounded-xl transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6 menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-primary/10">
    <div class="container-custom py-4 space-y-4">
      {navItems.map((item) => (
        item.megaMenu ? (
          <div class="mobile-dropdown">
            <button class="flex items-center justify-between w-full py-2 text-gray-600">
              {item.label}
              <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="mobile-dropdown-content hidden pl-4 space-y-2">
              {item.items.map((category) => (
                <div class="py-2">
                  <p class="text-xs font-semibold text-gray-900/40 uppercase tracking-wider mb-2">{category.category}</p>
                  {category.links.map((link) => (
                    <a href={link.href} class="block py-2 text-gray-600 hover:text-gray-900">
                      {link.label}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="block py-2 text-gray-600 hover:text-gray-900">
            {item.label}
          </a>
        )
      ))}
      <a href="#contact" class="btn-primary w-full justify-center mt-4">
        Get Started
      </a>
    </div>
  </div>
</header>

<script>
  // ── Announcement banner ──
  const banner = document.getElementById('announcement-banner');
  const closeBtn = document.getElementById('close-banner');
  const header = document.getElementById('main-header');

  function getBannerH() { return banner ? banner.offsetHeight : 0; }

  function applyBannerHeight() {
    const h = getBannerH();
    document.documentElement.style.setProperty('--banner-height', `${h}px`);
    if (header) header.style.top = `${h}px`;
  }

  function hideBanner() {
    if (!banner) return;
    banner.style.transform = 'translateY(-100%)';
    document.documentElement.style.setProperty('--banner-height', '0px');
    if (header) header.style.top = '0px';
  }

  function showBanner() {
    if (!banner) return;
    banner.style.transform = '';
    applyBannerHeight();
  }

  if (sessionStorage.getItem('banner-dismissed')) {
    banner?.remove();
    document.documentElement.style.setProperty('--banner-height', '0px');
    if (header) header.style.top = '0px';
  } else {
    applyBannerHeight();
    window.addEventListener('resize', applyBannerHeight);
  }

  closeBtn?.addEventListener('click', () => {
    banner?.remove();
    document.documentElement.style.setProperty('--banner-height', '0px');
    if (header) header.style.top = '0px';
    sessionStorage.setItem('banner-dismissed', '1');
  });

  // ── Header scroll effect ──
  // header already declared above
  let bannerHidden = false;

  function handleScroll() {
    const scrolled = window.scrollY > 10;

    // Collapse banner on any scroll, restore when back at top
    if (!sessionStorage.getItem('banner-dismissed')) {
      if (scrolled && !bannerHidden) {
        hideBanner();
        bannerHidden = true;
      } else if (!scrolled && bannerHidden) {
        showBanner();
        bannerHidden = false;
      }
    }

    // Header glass effect
    if (window.scrollY > 50) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = mobileMenuBtn?.querySelector('.menu-icon');
  const closeIcon = mobileMenuBtn?.querySelector('.close-icon');

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Mobile dropdown toggles
  document.querySelectorAll('.mobile-dropdown button').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
